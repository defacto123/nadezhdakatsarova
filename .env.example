# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------
# Public base URL of the storefront (no trailing slash)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Host that should render the admin CMS (optional). When a request arrives on
# this host it is rewritten to /admin. Leave empty to access admin via /admin.
ADMIN_HOST=""

# ---------------------------------------------------------------------------
# Database (PostgreSQL / Cloud SQL)
# ---------------------------------------------------------------------------
# Local example: postgresql://USER:PASSWORD@localhost:5432/boutique?schema=public
# Cloud SQL via unix socket example:
# postgresql://USER:PASSWORD@localhost/boutique?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/boutique?schema=public"

# ---------------------------------------------------------------------------
# Auth.js (NextAuth v5)
# ---------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-in-production"
AUTH_TRUST_HOST="true"
# Google OAuth
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Facebook OAuth
AUTH_FACEBOOK_ID=""
AUTH_FACEBOOK_SECRET=""

# ---------------------------------------------------------------------------
# Stripe
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY="sk_test_xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# ---------------------------------------------------------------------------
# Resend (transactional + marketing broadcasts)
# ---------------------------------------------------------------------------
RESEND_API_KEY="re_xxx"
# Verified sending identity
RESEND_FROM_EMAIL="Boutique <hello@example.com>"
# Audience id for marketing broadcasts (create in the Resend dashboard)
RESEND_AUDIENCE_ID=""

# ---------------------------------------------------------------------------
# Google Cloud Storage (product images)
# ---------------------------------------------------------------------------
GCS_BUCKET=""
GCS_PROJECT_ID=""
# Public base used to serve uploaded images (bucket public URL or CDN domain)
NEXT_PUBLIC_GCS_PUBLIC_BASE=""
# When running outside GCP, point this at a service-account key file.
# On Cloud Run the attached service account is used automatically.
GOOGLE_APPLICATION_CREDENTIALS=""

# ---------------------------------------------------------------------------
# Analytics
# ---------------------------------------------------------------------------
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# ---------------------------------------------------------------------------
# Seed admin (used by `npm run db:seed`)
# ---------------------------------------------------------------------------
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="admin12345"
