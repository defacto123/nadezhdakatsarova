// Art Boutique e-commerce data model.
// Prices are stored as integer euro cents to avoid floating point errors.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Auth.js models + application user
// ---------------------------------------------------------------------------

enum Role {
  USER
  ADMIN
}

model User {
  id               String                 @id @default(cuid())
  name             String?
  email            String                 @unique
  emailVerified    DateTime?
  image            String?
  passwordHash     String?
  role             Role                   @default(USER)
  marketingConsent Boolean                @default(false)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  accounts         Account[]
  sessions         Session[]
  orders           Order[]
  subscriber       NewsletterSubscriber?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Catalog
// ---------------------------------------------------------------------------

model Category {
  id            String     @id @default(cuid())
  slug          String     @unique
  nameBg        String
  nameEn        String
  descriptionBg String?    @db.Text
  descriptionEn String?    @db.Text
  image         String?
  sortOrder     Int        @default(0)
  active        Boolean    @default(true)
  parentId      String?
  parent        Category?  @relation("CategoryToCategory", fields: [parentId], references: [id], onDelete: SetNull)
  children      Category[] @relation("CategoryToCategory")
  products      Product[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Product {
  id            String           @id @default(cuid())
  slug          String           @unique
  titleBg       String
  titleEn       String
  descriptionBg String?          @db.Text
  descriptionEn String?          @db.Text
  // Base price in euro cents.
  priceCents    Int
  // Optional active sale, 1-100. Renders a ribbon and a strikethrough price.
  salePercent   Int?
  featured      Boolean          @default(false)
  isNew         Boolean          @default(false)
  active        Boolean          @default(true)
  soldCount     Int              @default(0)
  categoryId    String
  category      Category         @relation(fields: [categoryId], references: [id])
  images        ProductImage[]
  variants      ProductVariant[]
  orderItems    OrderItem[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([categoryId])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  sortOrder Int     @default(0)

  @@index([productId])
}

model ProductVariant {
  id                String      @id @default(cuid())
  productId         String
  product           Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  size              String?
  color             String?
  sku               String?     @unique
  // Warehouse stock count. Source of truth for in/out-of-stock on storefront.
  stock             Int         @default(0)
  // Optional per-variant price override in euro cents.
  priceOverrideCents Int?
  sortOrder         Int         @default(0)
  orderItems        OrderItem[]

  @@index([productId])
}

// ---------------------------------------------------------------------------
// Discounts
// ---------------------------------------------------------------------------

enum DiscountType {
  PERCENT
  FIXED
}

model DiscountCode {
  id            String       @id @default(cuid())
  code          String       @unique
  type          DiscountType
  // Percent (1-100) when PERCENT, euro cents when FIXED.
  value         Int
  minOrderCents Int?
  usageLimit    Int?
  usedCount     Int          @default(0)
  perUserLimit  Int?
  expiresAt     DateTime?
  active        Boolean      @default(true)
  createdAt     DateTime     @default(now())
  orders        Order[]
}

// ---------------------------------------------------------------------------
// Orders
// ---------------------------------------------------------------------------

enum OrderStatus {
  PENDING
  PAID
  FULFILLED
  CANCELLED
  REFUNDED
}

model Order {
  id                    String        @id @default(cuid())
  number                Int           @unique @default(autoincrement())
  userId                String?
  user                  User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  email                 String
  status                OrderStatus   @default(PENDING)
  currency              String        @default("EUR")
  subtotalCents         Int
  discountCents         Int           @default(0)
  shippingCents         Int           @default(0)
  totalCents            Int
  discountCodeId        String?
  discountCode          DiscountCode? @relation(fields: [discountCodeId], references: [id], onDelete: SetNull)
  stripePaymentIntentId String?       @unique
  stripeSessionId       String?       @unique

  shippingName       String?
  shippingPhone      String?
  shippingLine1      String?
  shippingLine2      String?
  shippingCity       String?
  shippingPostalCode String?
  shippingCountry    String?

  items     OrderItem[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id              String          @id @default(cuid())
  orderId         String
  order           Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String?
  product         Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variantId       String?
  variant         ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  titleSnapshot   String
  variantSnapshot String?
  unitPriceCents  Int
  quantity        Int

  @@index([orderId])
}

// ---------------------------------------------------------------------------
// Shipping
// ---------------------------------------------------------------------------

model ShippingZone {
  id        String         @id @default(cuid())
  name      String
  countries String[]
  sortOrder Int            @default(0)
  rates     ShippingRate[]
  createdAt DateTime       @default(now())
}

model ShippingRate {
  id           String       @id @default(cuid())
  zoneId       String
  zone         ShippingZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  name         String
  priceCents   Int
  // When set, the order ships free if subtotal >= this amount (euro cents).
  freeOverCents Int?
  sortOrder    Int          @default(0)

  @@index([zoneId])
}

// ---------------------------------------------------------------------------
// Marketing
// ---------------------------------------------------------------------------

model NewsletterSubscriber {
  id              String   @id @default(cuid())
  email           String   @unique
  consent         Boolean  @default(true)
  unsubscribed    Boolean  @default(false)
  resendContactId String?
  userId          String?  @unique
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())
}

enum CampaignStatus {
  DRAFT
  SENDING
  SENT
  FAILED
}

model Campaign {
  id               String         @id @default(cuid())
  subject          String
  preheader        String?
  bodyHtml         String         @db.Text
  status           CampaignStatus @default(DRAFT)
  resendBroadcastId String?
  recipientCount   Int            @default(0)
  sentAt           DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

// ---------------------------------------------------------------------------
// Site Design (CMS-managed theme, fonts, images, static content)
// ---------------------------------------------------------------------------

// Uploaded custom font file (woff2/woff/ttf/otf), assignable as body/heading.
model FontAsset {
  id        String   @id @default(cuid())
  label     String
  family    String
  url       String
  format    String
  createdAt DateTime @default(now())

  bodyThemes    SiteTheme[] @relation("BodyFont")
  headingThemes SiteTheme[] @relation("HeadingFont")
}

// Single-row theme configuration. Colors stored as hex strings mirroring the
// CSS design tokens; applied at runtime via injected CSS variables.
model SiteTheme {
  id                  String     @id @default("default")
  colorBackground     String     @default("#fbf7f0")
  colorForeground     String     @default("#2b2622")
  colorMutedText      String     @default("#6b6258")
  colorPrimary        String     @default("#c4633f")
  colorPrimaryHover   String     @default("#a64f30")
  colorSecondary      String     @default("#7d8a6a")
  colorSecondaryHover String     @default("#5f6b4f")
  colorAccent         String     @default("#e9c7b8")
  colorSurface        String     @default("#f1e8da")
  colorBorder         String     @default("#e6dccb")
  colorSale           String     @default("#c4633f")
  radiusRem           Float      @default(0.85)
  brushHue            Int        @default(0)
  brushSaturate       Int        @default(100)
  brushOpacity        Int        @default(75)
  bodyFontId          String?
  bodyFont           FontAsset? @relation("BodyFont", fields: [bodyFontId], references: [id], onDelete: SetNull)
  headingFontId       String?
  headingFont        FontAsset? @relation("HeadingFont", fields: [headingFontId], references: [id], onDelete: SetNull)
  updatedAt           DateTime   @updatedAt
}

// Named image slot (logo, hero, about-portrait, og-share, ...) with the exact
// dimensions enforced on upload.
model SiteImage {
  id        String   @id @default(cuid())
  slot      String   @unique
  url       String
  altBg     String?
  altEn     String?
  width     Int
  height    Int
  // Same per-image animation controls as hero slides. Site images default to
  // not animated (opt-in) so existing decorations don't suddenly move.
  animated  Boolean  @default(false)
  motion    String   @default("float") // float|sway|pulse|rock|drift
  speed     Int      @default(4) // 1 (slow) .. 10 (fast)
  bgColor   String?  // background behind the image; null = transparent
  updatedAt DateTime @updatedAt
}

// Editable static copy keyed by a registry key, bilingual.
model ContentBlock {
  id        String   @id @default(cuid())
  key       String   @unique
  valueBg   String   @db.Text
  valueEn   String   @db.Text
  updatedAt DateTime @updatedAt
}

// Repeatable hero slides shown on the homepage.
model HeroSlide {
  id         String   @id @default(cuid())
  // "single" = one big image (fade-in); "pair" = two images that slide in from
  // the left/right edges and gather in the centre.
  kind       String   @default("single")
  eyebrowBg  String?
  eyebrowEn  String?
  headlineBg String?
  headlineEn String?
  subtextBg  String?  @db.Text
  subtextEn  String?  @db.Text
  imageUrl   String?  // single image, or the left-edge image of a pair
  imageUrl2  String?  // right-edge image (pair only)
  href       String?  // redirect URL; the whole slide image(s) link here
  // Continuous motion per image. motion1/speed1 = single image or left of a
  // pair; motion2/speed2 = right of a pair. motion is one of
  // none|float|sway|pulse|rock|drift; speed is 1 (slow) .. 10 (fast).
  motion1    String   @default("float")
  speed1     Int      @default(4)
  animated1  Boolean  @default(true)
  motion2    String   @default("float")
  speed2     Int      @default(4)
  animated2  Boolean  @default(true)
  bgColor    String?  // band background colour; null = transparent
  ctaLabelBg String?
  ctaLabelEn String?
  ctaHref    String?
  sortOrder  Int      @default(0)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Footer / social media links.
model SocialLink {
  id        String  @id @default(cuid())
  platform  String
  url       String
  sortOrder Int     @default(0)
  active    Boolean @default(true)
}
